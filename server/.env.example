NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:3000

# Redis (optional for single-node, required for clustering)
REDIS_URL=redis://localhost:6379
USE_REDIS=false

# Game settings
MAX_PLAYERS_PER_ROOM=5
WORD_REVEAL_DURATION_MS=5000
DISCUSSION_DURATION_MS=60000
VOTING_DURATION_MS=30000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Security
ROOM_ID_LENGTH=8
